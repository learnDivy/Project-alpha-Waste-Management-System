<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>SmartWaste — Lucknow Municipal Smart Waste Management</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  :root{
    --green:#22c55e;--green-dark:#16a34a;--red:#ef4444;--red-dark:#dc2626;
    --yellow:#f59e0b;--blue:#3b82f6;--blue-dark:#2563eb;--purple:#8b5cf6;
    --gray-50:#f9fafb;--gray-100:#f3f4f6;--gray-200:#e5e7eb;--gray-300:#d1d5db;
    --gray-400:#9ca3af;--gray-500:#6b7280;--gray-600:#4b5563;--gray-700:#374151;
    --gray-800:#1f2937;--gray-900:#111827;
    --shadow:0 4px 6px -1px rgba(0,0,0,.1),0 2px 4px -2px rgba(0,0,0,.1);
    --shadow-lg:0 10px 15px -3px rgba(0,0,0,.1),0 4px 6px -4px rgba(0,0,0,.1);
  }
  body{font-family:'Inter',sans-serif;background:var(--gray-100);color:var(--gray-800);min-height:100vh}
  
  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar{width:6px;height:6px}::-webkit-scrollbar-track{background:var(--gray-100)}::-webkit-scrollbar-thumb{background:var(--gray-300);border-radius:3px}

  /* ─── AUTH SCREEN ─── */
  #auth-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 50%,#0f3460 100%);padding:20px}
  .auth-card{background:#fff;border-radius:24px;padding:48px 40px;width:100%;max-width:480px;box-shadow:0 25px 50px -12px rgba(0,0,0,.5)}
  .auth-logo{display:flex;align-items:center;gap:12px;margin-bottom:32px}
  .auth-logo-icon{width:52px;height:52px;background:linear-gradient(135deg,var(--green),var(--blue));border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px}
  .auth-logo-text h1{font-size:22px;font-weight:800;color:var(--gray-900)}
  .auth-logo-text p{font-size:12px;color:var(--gray-500)}
  .auth-subtitle{font-size:14px;color:var(--gray-500);margin-bottom:28px;line-height:1.6}
  .role-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px}
  .role-card{border:2px solid var(--gray-200);border-radius:12px;padding:14px 10px;text-align:center;cursor:pointer;transition:all .2s}
  .role-card:hover{border-color:var(--blue);background:#eff6ff}
  .role-card.selected{border-color:var(--blue);background:#eff6ff;box-shadow:0 0 0 3px rgba(59,130,246,.2)}
  .role-card-icon{font-size:24px;margin-bottom:6px}
  .role-card-label{font-size:12px;font-weight:600;color:var(--gray-700)}
  .form-group{margin-bottom:16px}
  .form-group label{display:block;font-size:13px;font-weight:600;color:var(--gray-700);margin-bottom:6px}
  .form-input{width:100%;padding:10px 14px;border:1.5px solid var(--gray-200);border-radius:10px;font-size:14px;font-family:inherit;transition:border-color .2s;outline:none}
  .form-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(59,130,246,.1)}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 18px;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;border:none;transition:all .2s;font-family:inherit}
  .btn-primary{background:var(--blue);color:#fff}.btn-primary:hover{background:var(--blue-dark)}
  .btn-success{background:var(--green);color:#fff}.btn-success:hover{background:var(--green-dark)}
  .btn-danger{background:var(--red);color:#fff}.btn-danger:hover{background:var(--red-dark)}
  .btn-ghost{background:var(--gray-100);color:var(--gray-700)}.btn-ghost:hover{background:var(--gray-200)}
  .btn-outline{background:transparent;color:var(--blue);border:1.5px solid var(--blue)}.btn-outline:hover{background:#eff6ff}
  .btn-sm{padding:6px 12px;font-size:12px}
  .btn-full{width:100%;margin-top:8px;padding:12px}
  .demo-creds{background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:10px;padding:14px;margin-top:16px}
  .demo-creds p{font-size:12px;font-weight:600;color:#166534;margin-bottom:6px}
  .demo-creds ul{list-style:none;font-size:12px;color:#15803d;line-height:2}
  .demo-creds strong{color:#166534}
  
  /* ─── APP SHELL ─── */
  #app{display:none;flex-direction:column;min-height:100vh}
  
  /* ─── NAVBAR ─── */
  .navbar{background:#fff;border-bottom:1px solid var(--gray-200);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:1000;box-shadow:var(--shadow)}
  .navbar-brand{display:flex;align-items:center;gap:10px}
  .navbar-brand-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--green),var(--blue));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px}
  .navbar-brand-text{font-size:16px;font-weight:800;color:var(--gray-900)}
  .navbar-center{display:flex;align-items:center;gap:4px}
  .nav-tab{padding:8px 16px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;color:var(--gray-600);transition:all .2s;border:none;background:none;font-family:inherit}
  .nav-tab:hover{background:var(--gray-100);color:var(--gray-800)}
  .nav-tab.active{background:#eff6ff;color:var(--blue);font-weight:600}
  .navbar-right{display:flex;align-items:center;gap:12px}
  .user-badge{display:flex;align-items:center;gap:8px;background:var(--gray-100);padding:6px 12px;border-radius:20px}
  .user-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff}
  .user-name{font-size:13px;font-weight:600;color:var(--gray-700)}
  .role-badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;text-transform:uppercase;letter-spacing:.5px}
  .role-admin{background:#fef3c7;color:#92400e}
  .role-employee{background:#dbeafe;color:#1e40af}
  .role-client{background:#d1fae5;color:#065f46}

  /* ─── ALERT BANNER ─── */
  .alert-banner{background:#fef2f2;border-bottom:2px solid #fecaca;padding:8px 24px;display:none;align-items:center;gap:10px;font-size:13px;color:var(--red-dark)}
  .alert-banner.show{display:flex}

  /* ─── MAIN ─── */
  .main-content{flex:1;padding:24px;max-width:1400px;width:100%;margin:0 auto}

  /* ─── STATS CARDS ─── */
  .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px}
  .stat-card{background:#fff;border-radius:14px;padding:20px;box-shadow:var(--shadow);display:flex;align-items:center;gap:16px;border-left:4px solid transparent}
  .stat-card.red{border-color:var(--red)}.stat-card.yellow{border-color:var(--yellow)}
  .stat-card.green{border-color:var(--green)}.stat-card.blue{border-color:var(--blue)}
  .stat-card.purple{border-color:var(--purple)}
  .stat-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
  .stat-icon.red{background:#fef2f2}.stat-icon.yellow{background:#fffbeb}
  .stat-icon.green{background:#f0fdf4}.stat-icon.blue{background:#eff6ff}.stat-icon.purple{background:#f5f3ff}
  .stat-value{font-size:28px;font-weight:800;color:var(--gray-900);line-height:1}
  .stat-label{font-size:12px;color:var(--gray-500);font-weight:500;margin-top:4px}

  /* ─── PANELS ─── */
  .panel-grid{display:grid;grid-template-columns:1fr 380px;gap:20px}
  .panel{background:#fff;border-radius:14px;box-shadow:var(--shadow);overflow:hidden}
  .panel-header{padding:16px 20px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between}
  .panel-title{font-size:15px;font-weight:700;color:var(--gray-800)}
  .panel-body{padding:16px}

  /* ─── MAP ─── */
  #map{height:480px;width:100%;border-radius:0}
  .map-legend{display:flex;gap:16px;flex-wrap:wrap;font-size:12px;color:var(--gray-600)}
  .legend-item{display:flex;align-items:center;gap:6px}
  .legend-dot{width:12px;height:12px;border-radius:50%}
  .legend-dot.red{background:var(--red)}.legend-dot.yellow{background:var(--yellow)}.legend-dot.green{background:var(--green)}.legend-dot.purple{background:var(--purple)}.legend-dot.blue{background:var(--blue)}

  /* ─── BIN LIST ─── */
  .bin-list{max-height:400px;overflow-y:auto}
  .bin-item{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:10px;cursor:pointer;transition:background .15s;border-bottom:1px solid var(--gray-50)}
  .bin-item:hover{background:var(--gray-50)}
  .bin-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
  .bin-dot.full{background:var(--red);box-shadow:0 0 0 3px rgba(239,68,68,.2)}
  .bin-dot.moderate{background:var(--yellow)}
  .bin-dot.low{background:var(--green)}
  .bin-info{flex:1;min-width:0}
  .bin-name{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .bin-area{font-size:11px;color:var(--gray-500)}
  .fill-bar-wrap{width:80px;flex-shrink:0}
  .fill-bar{height:6px;background:var(--gray-200);border-radius:3px;overflow:hidden;margin-bottom:2px}
  .fill-bar-inner{height:100%;border-radius:3px;transition:width .4s}
  .fill-bar-inner.full{background:var(--red)}.fill-bar-inner.moderate{background:var(--yellow)}.fill-bar-inner.low{background:var(--green)}
  .fill-pct{font-size:11px;font-weight:700;text-align:right}
  .fill-pct.full{color:var(--red)}.fill-pct.moderate{color:var(--yellow)}.fill-pct.low{color:var(--green)}

  /* ─── BADGES ─── */
  .badge{display:inline-flex;align-items:center;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.3px}
  .badge-red{background:#fef2f2;color:var(--red-dark)}.badge-yellow{background:#fffbeb;color:#92400e}
  .badge-green{background:#f0fdf4;color:var(--green-dark)}.badge-blue{background:#eff6ff;color:var(--blue-dark)}
  .badge-purple{background:#f5f3ff;color:#6d28d9}.badge-gray{background:var(--gray-100);color:var(--gray-600)}

  /* ─── ROUTE PANEL ─── */
  .route-step{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid var(--gray-100)}
  .route-step-num{width:24px;height:24px;border-radius:50%;background:var(--blue);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
  .route-step-info{flex:1}
  .route-step-name{font-size:13px;font-weight:600}
  .route-step-meta{font-size:11px;color:var(--gray-500);margin-top:2px}
  .route-step-action{flex-shrink:0}
  .check-btn{width:28px;height:28px;border-radius:50%;border:2px solid var(--gray-300);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
  .check-btn:hover{border-color:var(--green);color:var(--green)}
  .check-btn.checked{background:var(--green);border-color:var(--green);color:#fff}

  /* ─── COMPLAINT FORM ─── */
  .complaint-form{display:flex;flex-direction:column;gap:14px}
  .radio-group{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .radio-option{border:1.5px solid var(--gray-200);border-radius:10px;padding:10px 12px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:8px}
  .radio-option:hover{border-color:var(--blue)}
  .radio-option.selected{border-color:var(--blue);background:#eff6ff}
  .radio-option input{display:none}
  .radio-icon{font-size:18px}
  .radio-label{font-size:12px;font-weight:600;color:var(--gray-700)}
  textarea.form-input{resize:vertical;min-height:80px}
  .success-msg{background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:10px;padding:14px;text-align:center;color:var(--green-dark);font-size:14px;font-weight:600}

  /* ─── TABLES ─── */
  .data-table{width:100%;border-collapse:collapse;font-size:13px}
  .data-table th{background:var(--gray-50);padding:10px 12px;text-align:left;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--gray-600);border-bottom:2px solid var(--gray-200)}
  .data-table td{padding:10px 12px;border-bottom:1px solid var(--gray-100);color:var(--gray-700);vertical-align:middle}
  .data-table tbody tr:hover{background:var(--gray-50)}
  .data-table-wrap{overflow-x:auto}

  /* ─── TABS INSIDE PANELS ─── */
  .inner-tabs{display:flex;gap:4px;padding:8px 16px;border-bottom:1px solid var(--gray-100)}
  .inner-tab{padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;color:var(--gray-600);transition:all .2s;border:none;background:none;font-family:inherit}
  .inner-tab.active{background:#eff6ff;color:var(--blue)}
  .tab-panel{display:none;padding:16px}.tab-panel.active{display:block}

  /* ─── RECYCLE SECTION ─── */
  .recycle-section{background:#fff;border-radius:14px;box-shadow:var(--shadow);padding:32px;margin-top:24px}
  .recycle-title{font-size:22px;font-weight:800;color:var(--gray-900);margin-bottom:8px}
  .recycle-subtitle{font-size:14px;color:var(--gray-500);margin-bottom:28px}
  .waste-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}
  .waste-card{border-radius:14px;padding:24px;color:#fff;position:relative;overflow:hidden}
  .waste-card::before{content:'';position:absolute;top:-20px;right:-20px;width:80px;height:80px;border-radius:50%;background:rgba(255,255,255,.15)}
  .waste-card.plastic{background:linear-gradient(135deg,#3b82f6,#1d4ed8)}
  .waste-card.glass{background:linear-gradient(135deg,#14b8a6,#0d9488)}
  .waste-card.paper{background:linear-gradient(135deg,#f59e0b,#d97706)}
  .waste-card.organic{background:linear-gradient(135deg,#22c55e,#16a34a)}
  .waste-card.ewaste{background:linear-gradient(135deg,#8b5cf6,#7c3aed)}
  .waste-card-icon{font-size:32px;margin-bottom:12px}
  .waste-card-title{font-size:16px;font-weight:800;margin-bottom:10px}
  .waste-card-tips{list-style:none;font-size:12px;line-height:1.9;opacity:.92}
  .waste-card-tips li::before{content:'✓ '}

  /* ─── CHECKIN CARD ─── */
  .checkin-card{background:linear-gradient(135deg,var(--blue),var(--blue-dark));border-radius:14px;padding:24px;color:#fff;margin-bottom:20px}
  .checkin-card h3{font-size:16px;font-weight:700;margin-bottom:4px}
  .checkin-card p{font-size:13px;opacity:.85;margin-bottom:16px}
  .checkin-time{font-size:28px;font-weight:800;margin-bottom:4px}
  .checkin-meta{font-size:12px;opacity:.8}
  .progress-bar{height:8px;background:rgba(255,255,255,.25);border-radius:4px;overflow:hidden;margin-top:16px}
  .progress-fill{height:100%;background:#fff;border-radius:4px;transition:width .5s}
  .progress-label{font-size:12px;opacity:.8;margin-top:6px}

  /* ─── MODALS ─── */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:2000;display:none;align-items:center;justify-content:center;padding:20px}
  .modal-overlay.open{display:flex}
  .modal{background:#fff;border-radius:20px;padding:28px;width:100%;max-width:480px;box-shadow:0 20px 40px rgba(0,0,0,.3)}
  .modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
  .modal-title{font-size:18px;font-weight:800;color:var(--gray-900)}
  .modal-close{width:32px;height:32px;border:none;background:var(--gray-100);border-radius:50%;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center}

  /* ─── NOTIFICATIONS ─── */
  .toast-container{position:fixed;top:80px;right:24px;z-index:3000;display:flex;flex-direction:column;gap:8px;max-width:340px}
  .toast{background:#fff;border-radius:12px;padding:14px 16px;box-shadow:var(--shadow-lg);display:flex;align-items:flex-start;gap:10px;animation:slideIn .3s ease;border-left:4px solid var(--blue)}
  .toast.error{border-color:var(--red)}.toast.success{border-color:var(--green)}.toast.warning{border-color:var(--yellow)}
  .toast-icon{font-size:18px;flex-shrink:0}
  .toast-body{flex:1}
  .toast-title{font-size:13px;font-weight:700;color:var(--gray-800)}
  .toast-msg{font-size:12px;color:var(--gray-600);margin-top:2px}
  @keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}

  /* ─── LOADING ─── */
  .spinner{width:20px;height:20px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:inline-block}
  @keyframes spin{to{transform:rotate(360deg)}}

  /* ─── SECTION ─── */
  .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
  .section-title{font-size:18px;font-weight:800;color:var(--gray-900)}
  .section-meta{font-size:13px;color:var(--gray-500)}

  /* ─── PULSE ANIMATION ─── */
  .pulse{animation:pulse 2s cubic-bezier(.4,0,.6,1) infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

  /* ─── SCROLLABLE WRAPPER ─── */
  .scroll-wrap{max-height:350px;overflow-y:auto}

  /* ─── EMPTY STATE ─── */
  .empty-state{text-align:center;padding:40px;color:var(--gray-400)}
  .empty-state-icon{font-size:40px;margin-bottom:12px}
  .empty-state-text{font-size:14px}

  /* ─── RESPONSIVE ─── */
  @media(max-width:900px){.panel-grid{grid-template-columns:1fr}.navbar-center{display:none}}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════ AUTH SCREEN ═══════════════════════════════════════ -->
<div id="auth-screen">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-icon">🗑️</div>
      <div class="auth-logo-text">
        <h1>SmartWaste</h1>
        <p>Lucknow Municipal Corporation</p>
      </div>
    </div>
    <p class="auth-subtitle">IoT-powered waste management system for smarter, cleaner cities. Select your role to continue.</p>
    
    <div class="role-cards">
      <div class="role-card selected" onclick="selectRole('admin')" id="role-admin">
        <div class="role-card-icon">👨‍💼</div>
        <div class="role-card-label">Admin</div>
      </div>
      <div class="role-card" onclick="selectRole('employee')" id="role-employee">
        <div class="role-card-icon">👷</div>
        <div class="role-card-label">Employee</div>
      </div>
      <div class="role-card" onclick="selectRole('client')" id="role-client">
        <div class="role-card-icon">🏘️</div>
        <div class="role-card-label">Citizen</div>
      </div>
    </div>

    <div class="form-group">
      <label>Email Address</label>
      <input type="email" id="login-email" class="form-input" placeholder="Enter your email" value="admin@smartwaste.in" />
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" id="login-password" class="form-input" placeholder="Enter password" value="Admin@123" />
    </div>
    <button class="btn btn-primary btn-full" onclick="handleLogin()">
      <span id="login-btn-text">Sign In →</span>
    </button>

    <div class="demo-creds">
      <p>🔑 Demo Credentials</p>
      <ul>
        <li><strong>Admin:</strong> admin@smartwaste.in / Admin@123</li>
        <li><strong>Employee:</strong> employee1@smartwaste.in / Emp@123</li>
        <li><strong>Citizen:</strong> client@smartwaste.in / Client@123</li>
      </ul>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════ TOAST CONTAINER ═══════════════════════════════════════ -->
<div class="toast-container" id="toast-container"></div>

<!-- ═══════════════════════════════════════ MAIN APP ═══════════════════════════════════════ -->
<div id="app">
  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="navbar-brand">
      <div class="navbar-brand-icon">🗑️</div>
      <div class="navbar-brand-text">SmartWaste LKO</div>
    </div>
    <div class="navbar-center" id="nav-tabs"></div>
    <div class="navbar-right">
      <div class="user-badge">
        <div class="user-avatar" id="user-avatar" style="background:var(--blue)">A</div>
        <span class="user-name" id="user-name-display">Admin</span>
        <span class="role-badge" id="user-role-badge">Admin</span>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="logout()">Logout</button>
    </div>
  </nav>

  <!-- ALERT BANNER -->
  <div class="alert-banner" id="alert-banner">
    <span>🚨</span>
    <span id="alert-text">Warning: Multiple bins critically full</span>
    <button class="btn btn-danger btn-sm" style="margin-left:auto" onclick="dismissAlert()">Dismiss</button>
  </div>

  <!-- MAIN CONTENT -->
