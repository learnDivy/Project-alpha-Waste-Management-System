function sortByNearestNeighbor(arr) {
  if (arr.length < 2) return;
  const depot = {lat:26.8467,lng:80.9462};
  const result = [];
  const rem = [...arr.map((_,i)=>i)];
  let cur = depot;
  while (rem.length) {
    let best = 0, bestDist = Infinity;
    rem.forEach((ri,i)=>{ const d=haversine(cur.lat,cur.lng,arr[ri].lat,arr[ri].lng); if(d<bestDist){bestDist=d;best=i;} });
    result.push(rem[best]);
    cur = arr[rem[best]];
    rem.splice(best,1);
  }
  const sorted = result.map(i=>arr[i]);
  arr.length = 0;
  sorted.forEach(x=>arr.push(x));
}

