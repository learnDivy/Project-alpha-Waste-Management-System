  L.marker([26.8467, 80.9462], {
    icon: L.divIcon({
      className:'',
      html:`<div style="width:36px;height:36px;border-radius:8px;background:#7c3aed;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;font-size:16px">🏢</div>`,
      iconSize:[36,36],iconAnchor:[18,18]
    })
  }).addTo(mapInstance).bindPopup('<strong>LMC Depot</strong><br>Hazratganj, Lucknow');

  // Draw route if exists
  if (generatedRoute) drawRouteOnMap();
}

function drawRouteOnMap() {
  if (!mapInstance || !generatedRoute) return;
  if (routeLayer) { mapInstance.removeLayer(routeLayer); routeLayer = null; }
  const depot = [26.8467, 80.9462];
  const coords = [depot, ...generatedRoute.bins.map(b=>[b.lat,b.lng]), depot];
  routeLayer = L.polyline(coords, {color:'#3b82f6',weight:4,opacity:.85,dashArray:'10,6'}).addTo(mapInstance);
  mapInstance.fitBounds(routeLayer.getBounds(), {padding:[30,30]});
}

function collectBin(binId) {
  const b = bins.find(x=>x.id===binId);
  if (b) {
    b.fill = 0; b.status = 'low'; b.collected = true;
    if (taskBins) { const tb = taskBins.find(x=>x.id===binId); if(tb) tb.done=true; }
    mapInstance?.closePopup();
    showToast('success','Bin Collected',`${b.loc} has been cleared.`);
    initMap(currentRole==='employee');
  }
}

// ═══════════════════════════════════════════════════════════════════
// ROUTE GENERATION (Nearest Neighbor TSP)
// ═══════════════════════════════════════════════════════════════════
function generateRoute() {
  const fullBins = bins.filter(b=>b.fill>=80);
  if (fullBins.length===0) { showToast('info','No Full Bins','All bins are below 80% fill level.'); return; }

  showToast('info','Generating Route...','Running Nearest Neighbor TSP algorithm...');

  setTimeout(() => {
    const sorted = [...fullBins];
    sortByNearestNeighbor(sorted);
    const depot = {lat:26.8467,lng:80.9462};
    let dist = 0, cur = depot;
    for (const b of sorted) { dist += haversine(cur.lat,cur.lng,b.lat,b.lng); cur=b; }
    dist += haversine(cur.lat,cur.lng,depot.lat,depot.lng);

    generatedRoute = {
      id: 'RT-' + Date.now().toString().slice(-6),
      bins: sorted,
      dist: dist.toFixed(2),
      time: Math.round(dist/20*60 + sorted.length*5),
      algo: 'Nearest Neighbor TSP'
    };
    taskBins = sorted.map(b=>({...b, done:false}));

    showToast('success','Route Generated!',`${sorted.length} bins · ${dist.toFixed(2)} km · ~${generatedRoute.time} min`);
    renderDashboard();
    if (mapInstance) drawRouteOnMap();
  }, 1200);
}

function clearRoute() {
  generatedRoute = null;
  if (routeLayer && mapInstance) { mapInstance.removeLayer(routeLayer); routeLayer = null; }
  renderDashboard();
}

function haversine(lat1,lon1,lat2,lon2) {
  const R=6371,dLat=(lat2-lat1)*Math.PI/180,dLon=(lon2-lon1)*Math.PI/180;
  const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

