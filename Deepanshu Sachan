function markBinDone(binId, btn) {
  const b = taskBins.find(x=>x.id===binId);
  if (b) {
    b.done = !b.done;
    btn.classList.toggle('checked');
    const bin = bins.find(x=>x.id===binId);
    if (bin) { bin.fill = 0; bin.status = 'low'; bin.collected = true; }
    const done = taskBins.filter(x=>x.done).length;
    showToast(b.done?'success':'info', b.done?'Bin Collected':'Unmarked', `${b.loc} ${b.done?'marked as collected':'unmarked'}`);
    if (done === taskBins.length) showToast('success','🎉 Route Complete!','All bins collected for today!');
  }
}

function calcRouteDist(arr) {
  if (!arr || arr.length===0) return '0.00';
  const depot = {lat:26.8467,lng:80.9462};
  let dist = 0, cur = depot;
  for (const b of arr) { dist += haversine(cur.lat,cur.lng,b.lat,b.lng); cur=b; }
  dist += haversine(cur.lat,cur.lng,depot.lat,depot.lng);
  return dist.toFixed(2);
}

