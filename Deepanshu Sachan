  }).addTo(mapInstance);

  mapMarkers = [];
  const activeBins = employeeView ? taskBins : bins;

  activeBins.forEach(b => {
    const color = b.fill>=80?'#ef4444':b.fill>=50?'#f59e0b':'#22c55e';
    const icon = L.divIcon({
      className: '',
