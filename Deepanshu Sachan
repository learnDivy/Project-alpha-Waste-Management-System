    <div style="background:var(--gray-50);border-radius:10px;padding:16px;margin-bottom:16px">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px"><span style="color:var(--gray-600)">Bin ID</span><strong>${b.id}</strong></div>
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px"><span style="color:var(--gray-600)">Coordinates</span><span>${b.lat.toFixed(4)}, ${b.lng.toFixed(4)}</span></div>
      <div style="display:flex;justify-content:space-between;margin-bottom:12px;font-size:13px"><span style="color:var(--gray-600)">Capacity</span><strong>${b.cap}L</strong></div>
      <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px">
        <span style="color:var(--gray-600)">Fill Level</span>
        <strong style="color:${color};font-size:20px">${b.fill}%</strong>
      </div>
      <div style="height:10px;background:#e5e7eb;border-radius:5px;overflow:hidden">
        <div style="height:100%;background:${color};width:${b.fill}%;border-radius:5px;transition:width .5s"></div>
      </div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-success" style="flex:1" onclick="collectBinModal('${b.id}')">✓ Mark Collected</button>
      <button class="btn btn-ghost" style="flex:1" onclick="closeBinModal()">Close</button>
    </div>`;
  document.getElementById('bin-modal').classList.add('open');
}

function collectBinModal(binId) {
  collectBin(binId);
  closeBinModal();
}

function closeBinModal() {
  document.getElementById('bin-modal').classList.remove('open');
}

// ═══════════════════════════════════════════════════════════════════
// TOAST NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════════
function showToast(type, title, msg) {
  const icons = {success:'✅',error:'❌',warning:'⚠️',info:'ℹ️'};
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.innerHTML = `<div class="toast-icon">${icons[type]||'ℹ️'}</div><div class="toast-body"><div class="toast-title">${title}</div><div class="toast-msg">${msg}</div></div>`;
  container.appendChild(toast);
  setTimeout(() => { toast.style.opacity='0'; toast.style.transform='translateX(100%)'; toast.style.transition='all .3s'; setTimeout(()=>toast.remove(),300); }, 4000);
}

// ═══════════════════════════════════════════════════════════════════
// EARLY WARNING SYSTEM — ALERT BANNER
// ═══════════════════════════════════════════════════════════════════
function checkAlerts() {
  const critical = bins.filter(b=>b.fill>=95);
  const banner = document.getElementById('alert-banner');
  if (critical.length > 0 && currentRole==='admin') {
    document.getElementById('alert-text').textContent = 
      `🚨 ALERT: ${critical.length} bin(s) critically full (≥95%) — ${critical.map(b=>b.loc).join(', ')}`;
    banner.classList.add('show');
  } else {
    banner.classList.remove('show');
  }
}

function dismissAlert() {
  document.getElementById('alert-banner').classList.remove('show');
}

// ═══════════════════════════════════════════════════════════════════
// LIVE SIMULATION — Fill levels slowly increase
// ═══════════════════════════════════════════════════════════════════
function startSimulation() {
  checkAlerts();
  setInterval(() => {
    const rates = {'Market':0.4,'Railway Station':0.6,'School':0.2,'Residential':0.25,'Park':0.1};
    bins.forEach(b => {
      if (b.collected) return;
      const rate = rates[b.area] || 0.2;
      const delta = (Math.random() * rate * 2 - rate * 0.5);
      b.fill = Math.min(100, Math.max(0, b.fill + delta));
      b.fill = parseFloat(b.fill.toFixed(1));
      b.status = b.fill>=80?'full':b.fill>=50?'moderate':'low';
    });
    checkAlerts();
    // Update bin list sidebar if visible
    const sidebar = document.getElementById('bin-list-sidebar');
    if (sidebar) sidebar.innerHTML = renderBinListHTML();
  }, 8000);
}

// Close modal on overlay click
document.getElementById('bin-modal').addEventListener('click', function(e) {
  if (e.target === this) closeBinModal();
});
</script>
